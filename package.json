{
  "name": "tradealgo-smartapi-nifty50",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node src/check.js",
    "plan4": "node src/plan4Engine.js",
    "plan4:silver": "node src/recordSilver.js",
    "plan4:gold": "node src/recordGold.js",
    "push:csv": "node src/pushCsvToTelegram.js",
    "push:csv:now": "node src/pushCsvToTelegram.js --now",
    "push:csv:gold": "node src/pushCsvToTelegram.js --market GOLD",
    "push:csv:gold:now": "node src/pushCsvToTelegram.js --market GOLD --now",
    "push:csv:silver": "node src/pushCsvToTelegram.js --market SILVER",
    "push:csv:silver:now": "node src/pushCsvToTelegram.js --market SILVER --now",
    "pm2:start": "pm2 start ecosystem.config.js && pm2 stop ecosystem.config.js && pm2 save",
    "pm2:status": "pm2 list",
    "pm2:logs": "pm2 logs",
    "pm2:reload": "pm2 delete ecosystem.config.js; pm2 start ecosystem.config.js && pm2 stop ecosystem.config.js && pm2 save"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "mongodb": "^6.17.0",
    "smartapi-javascript": "^1.0.27"
  }
}